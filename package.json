{
  "name": "chess-trainer",
  "version": "0.2.6",
  "private": true,
  "packageManager": "pnpm@10.18.2",
  "description": "Chess Trainer web app for PGN import, analysis, and puzzle review.",
  "scripts": {
    "dev": "pnpm --dir apps/web run dev",
    "build": "pnpm --dir apps/web run build",
    "typecheck": "pnpm --dir apps/web run typecheck",
    "test": "pnpm --dir apps/web run test:tdd",
    "convex:dev": "pnpm --dir apps/web run convex:dev",
    "convex:deploy": "pnpm --dir apps/web run convex:deploy",
    "vercel:whoami": "vercel whoami",
    "vercel:login": "vercel login",
    "vercel:link": "vercel link",
    "vercel:pull": "vercel pull --yes",
    "vercel:dev": "vercel dev",
    "vercel:build": "vercel build",
    "vercel:deploy": "vercel deploy",
    "vercel:deploy:prod": "vercel deploy --prod",
    "web:dev": "pnpm --dir apps/web run dev",
    "web:build": "pnpm --dir apps/web run build"
  },
  "keywords": [
    "chess",
    "pgn",
    "analysis",
    "puzzles",
    "convex",
    "vercel"
  ],
  "author": "Chess Trainer Team",
  "license": "MIT",
  "engines": {
    "node": "20.x",
    "npm": "10.x"
  },
  "devDependencies": {}
}
