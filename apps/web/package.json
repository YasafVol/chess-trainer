{
  "name": "chess-trainer-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "20.x",
    "npm": "10.x"
  },
  "scripts": {
    "dev": "node ./node_modules/vite/bin/vite.js",
    "build": "node ./node_modules/typescript/bin/tsc -b && node ./node_modules/vite/bin/vite.js build",
    "preview": "node ./node_modules/vite/bin/vite.js preview",
    "typecheck": "node ./node_modules/typescript/bin/tsc -b --pretty false",
    "test:tdd": "node ./scripts/compile-tests.mjs && node ./scripts/run-node-tests.mjs",
    "test:tdd:one": "node ./node_modules/typescript/bin/tsc -p tsconfig.test.json --pretty false && node --test --test-name-pattern \"$TEST_NAME\" .tmp-test-build/src/**/*.test.js",
    "convex:dev": "node ./node_modules/convex/bin/main.js dev",
    "convex:deploy": "node ./node_modules/convex/bin/main.js deploy"
  },
  "dependencies": {
    "@auth/core": "^0.37.4",
    "@chess-trainer/chess-core": "file:../../packages/chess-core",
    "@convex-dev/auth": "^0.0.91",
    "@tanstack/react-router": "^1.120.5",
    "chess.js": "^1.4.0",
    "chessboard-element": "^1.2.0",
    "convex": "^1.32.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "stockfish": "^18.0.5"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.13",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "@vitest/coverage-v8": "^4.0.18",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^28.1.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^4.0.18"
  }
}
