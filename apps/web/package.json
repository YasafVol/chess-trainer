{
  "name": "chess-trainer-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "20.x",
    "npm": "10.x"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --pretty false",
    "test:tdd": "tsc -p tsconfig.test.json --pretty false && node --test .tmp-test-build/src/**/*.test.js",
    "test:tdd:one": "./node_modules/.bin/tsc -p tsconfig.test.json --pretty false && node --test --test-name-pattern \"$TEST_NAME\" .tmp-test-build/src/**/*.test.js"
  },
  "dependencies": {
    "@chess-trainer/chess-core": "file:../../packages/chess-core",
    "@tanstack/react-router": "^1.120.5",
    "chess.js": "^1.4.0",
    "chessboard-element": "^1.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "stockfish": "^18.0.5"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.13",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "@vitest/coverage-v8": "^4.0.18",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^28.1.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^4.0.18"
  }
}
