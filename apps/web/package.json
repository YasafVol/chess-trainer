{
  "name": "chess-trainer-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "20.x",
    "npm": "10.x"
  },
  "scripts": {
    "generate:fitl-graph": "node ./scripts/generate-fitl-graph.mjs",
    "dev": "node ./scripts/generate-fitl-graph.mjs && npx vite",
    "build": "node ./scripts/generate-fitl-graph.mjs && node ./node_modules/typescript/bin/tsc -b && npx vite build",
    "preview": "npx vite preview",
    "typecheck": "node ./scripts/generate-fitl-graph.mjs && node ./node_modules/typescript/bin/tsc -b --pretty false",
    "test:tdd": "node ./scripts/generate-fitl-graph.mjs && node ./scripts/compile-tests.mjs && node ./scripts/run-node-tests.mjs",
    "test:tdd:one": "node ./scripts/generate-fitl-graph.mjs && node ./node_modules/typescript/bin/tsc -p tsconfig.test.json --pretty false && node --test --test-name-pattern \"$TEST_NAME\" .tmp-test-build/src/**/*.test.js",
    "convex:dev": "npx convex dev",
    "convex:deploy": "npx convex deploy"
  },
  "dependencies": {
    "@auth/core": "^0.37.4",
    "@base-ui/react": "^1.3.0",
    "@chess-trainer/chess-core": "file:../../packages/chess-core",
    "@convex-dev/auth": "^0.0.91",
    "@fontsource-variable/geist": "^5.2.8",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-router": "^1.120.5",
    "chess.js": "^1.4.0",
    "chessboard-element": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.32.0",
    "lucide-react": "^0.577.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "shadcn": "^4.0.8",
    "stockfish": "^18.0.5",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.13",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "@vitest/coverage-v8": "^4.0.18",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^28.1.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^4.0.18"
  }
}
